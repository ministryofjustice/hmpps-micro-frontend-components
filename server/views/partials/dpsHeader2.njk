        </svg>
        <span>Digital Prison Services</span>
      </a>
    </div>

    <div class="cdps-header__item cdps-header__item--spacer">
      {% if environmentName %}
        {{ govukTag({
          text: environmentName,
          classes: environmentNameColour,
          attributes: {
            'data-qa': 'connect-dps-common-environment-tag'
          }
        }) }}
      {% endif %}
    </div>

    {% set hasSeveralCaseLoads = user.caseLoads.length > 1 %}
    <div class="cdps-header__item cdps-header__item--caseload {% if not hasSeveralCaseLoads %}cdps-header__item--few-caseloads{% endif %}">
      {% if hasSeveralCaseLoads %}
        <a class="cdps-header__link" href="{{ changeCaseLoadLink }}">
          <span class="cdps-header__link-wrapper">
            <svg class="cdps-header__icon--caseload" width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
