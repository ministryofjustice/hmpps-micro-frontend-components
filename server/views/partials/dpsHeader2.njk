{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

<header class="cdps-header" data-module="cdps-header">
  <nav class="govuk-width-container cdps-header__container" aria-label="DPS navigation menu">
    <div class="cdps-header__item cdps-header__item--crest">
      <a class="cdps-header__link" href="{{ config.serviceUrls.dps.url }}">
        <svg class="cdps-header__icon--crest" width="32" height="30" viewBox="0 0 32 30" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
          <path fill="currentColor" d="M22.6 10.4c-1 .4-2-.1-2.4-1s.1-2 1-2.4 2 .1 2.4 1-.1 2-1 2.4m-5.9 6.7c-.9.4-2-.1-2.4-1s.1-2 1-2.4 2 .1 2.4 1-.1 2-1 2.4m10.8-3.7c-1 .4-2-.1-2.4-1s.1-2 1-2.4 2 .1 2.4 1 0 2-1 2.4m3.3 4.8c-1 .4-2-.1-2.4-1s.1-2 1-2.4 2 .1 2.4 1-.1 2-1 2.4M17 4.7l2.3 1.2V2.5l-2.3.7-.2-.2.9-3h-3.4l.9 3-.2.2c-.1.1-2.3-.7-2.3-.7v3.4L15 4.7c.1.1.1.2.2.2l-1.3 4c-.1.2-.1.4-.1.6 0 1.1.8 2 1.9 2.2h.7c1-.2 1.9-1.1 1.9-2.1 0-.2 0-.4-.1-.6l-1.3-4c-.1-.2 0-.2.1-.3m-7.6 5.7c.9.4 2-.1 2.4-1s-.1-2-1-2.4-2 .1-2.4 1 0 2 1 2.4m-5 3c.9.4 2-.1 2.4-1s-.1-2-1-2.4-2 .1-2.4 1 .1 2 1 2.4m-3.2 4.8c.9.4 2-.1 2.4-1s-.1-2-1-2.4-2 .1-2.4 1 0 2 1 2.4m14.8 11c4.4 0 8.6.3 12.3.8 1.1-4.5 2.4-7 3.7-8.8l-2.5-.9c.2 1.3.3 1.9 0 2.7-.4-.4-.8-1.1-1.1-2.3l-1.2 4c.7-.5 1.3-.8 2-.9-1.1 2.5-2.6 3.1-3.5 3-1.1-.2-1.7-1.2-1.5-2.1.3-1.2 1.5-1.5 2.1-.1 1.1-2.3-.8-3-2-2.3 1.9-1.9 2.1-3.5.6-5.6-2.1 1.6-2.1 3.2-1.2 5.5-1.2-1.4-3.2-.6-2.5 1.6.9-1.4 2.1-.5 1.9.8-.2 1.1-1.7 2.1-3.5 1.9-2.7-.2-2.9-2.1-2.9-3.6.7-.1 1.9.5 2.9 1.9l.4-4.3c-1.1 1.1-2.1 1.4-3.2 1.4.4-1.2 2.1-3 2.1-3h-5.4s1.7 1.9 2.1 3c-1.1 0-2.1-.2-3.2-1.4l.4 4.3c1-1.4 2.2-2 2.9-1.9-.1 1.5-.2 3.4-2.9 3.6-1.9.2-3.4-.8-3.5-1.9-.2-1.3 1-2.2 1.9-.8.7-2.3-1.2-3-2.5-1.6.9-2.2.9-3.9-1.2-5.5-1.5 2-1.3 3.7.6 5.6-1.2-.7-3.1 0-2 2.3.6-1.4 1.8-1.1 2.1.1.2.9-.3 1.9-1.5 2.1-.9.2-2.4-.5-3.5-3 .6 0 1.2.3 2 .9l-1.2-4c-.3 1.1-.7 1.9-1.1 2.3-.3-.8-.2-1.4 0-2.7l-2.9.9C1.3 23 2.6 25.5 3.7 30c3.7-.5 7.9-.8 12.3-.8"/>
        </svg>
        <span>Digital Prison Services</span>
      </a>
    </div>

    <div class="cdps-header__item cdps-header__item--spacer">
      {% if environmentName %}
        {{ govukTag({
          text: environmentName,
          classes: environmentNameColour,
          attributes: {
            'data-qa': 'connect-dps-common-environment-tag'
          }
        }) }}
      {% endif %}
    </div>

    {% set hasSeveralCaseLoads = user.caseLoads.length > 1 %}
    <div class="cdps-header__item cdps-header__item--caseload {% if not hasSeveralCaseLoads %}cdps-header__item--few-caseloads{% endif %}">
      {% if hasSeveralCaseLoads %}
        <a class="cdps-header__link" href="{{ changeCaseLoadLink }}" data-qa="connect-dps-caseload-switcher">
          <span class="cdps-header__link-wrapper">
            <svg class="cdps-header__icon--caseload" width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
              <path fill="currentColor" d="M13 25.187q-3.168 0-5.178-.956-2.01-.957-2.01-2.481 0-.913.769-1.624.768-.71 2.12-1.167l.54 1.786a4.6 4.6 0 0 0-.993.487q-.402.27-.522.518.31.669 1.845 1.115 1.534.448 3.429.448 1.882 0 3.433-.448 1.55-.447 1.86-1.115-.12-.248-.521-.512a5.3 5.3 0 0 0-.993-.493l.55-1.786q1.354.457 2.106 1.167t.752 1.624q0 1.524-2.01 2.48-2.009.957-5.177.957m0-7.382q.563-1.067 1.26-2.07.696-1.005 1.399-1.918 1.18-1.535 1.886-2.781.705-1.245.705-3.099 0-2.182-1.534-3.716Q15.184 2.688 13 2.687q-2.183 0-3.716 1.534T7.75 7.937q0 1.854.712 3.099.71 1.245 1.88 2.781.701.914 1.398 1.917.697 1.005 1.26 2.071m0 3.248a.9.9 0 0 1-.565-.203 1.2 1.2 0 0 1-.382-.523q-.767-2.1-1.825-3.52a496 496 0 0 0-2.04-2.725 18 18 0 0 1-1.633-2.7q-.68-1.396-.68-3.445 0-2.993 2.066-5.058Q10.008.813 13 .813t5.059 2.066 2.066 5.058q0 2.049-.665 3.445t-1.647 2.7q-.952 1.303-2.026 2.724-1.073 1.423-1.84 3.52-.124.32-.382.524a.9.9 0 0 1-.565.203m0-10.832q.95 0 1.617-.667.666-.668.667-1.617 0-.949-.667-1.616A2.2 2.2 0 0 0 13 5.654q-.95 0-1.617.667a2.2 2.2 0 0 0-.667 1.616q0 .95.667 1.617.668.667 1.617.667"/>
            </svg>
            <span>{{ user.activeCaseLoad.name }}</span>
            <span class="govuk-visually-hidden">Change caseload</span>
          </span>
        </a>
      {% endif %}
    </div>

    <div class="cdps-header__item cdps-header__item--user">
      <a class="cdps-header__link" href="{{ manageDetailsLink }}">
        <span class="cdps-header__link-wrapper">
          <svg class="cdps-header__icon--user" width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M5.529 19.615A13.6 13.6 0 0 1 9 17.748 11.6 11.6 0 0 1 13 17.062q2.12 0 3.999.686 1.879.684 3.472 1.867a9.9 9.9 0 0 0 1.847-2.966Q23 14.964 23 13q0-4.155-2.922-7.078T13 3Q8.845 3 5.922 5.922T3 13q0 1.965.681 3.649a9.9 9.9 0 0 0 1.848 2.966M13 13.937q-1.71 0-2.887-1.175-1.176-1.174-1.175-2.887 0-1.71 1.175-2.887Q11.287 5.812 13 5.812q1.71 0 2.887 1.176 1.176 1.174 1.175 2.887 0 1.71-1.175 2.887-1.174 1.176-2.887 1.175m0 10.938q-2.475 0-4.64-.93a11.9 11.9 0 0 1-3.771-2.534 11.9 11.9 0 0 1-2.534-3.77q-.93-2.168-.93-4.641 0-2.475.93-4.64A11.9 11.9 0 0 1 4.59 4.588a11.9 11.9 0 0 1 3.77-2.534q2.167-.93 4.641-.93t4.64.93a11.9 11.9 0 0 1 3.771 2.534 11.9 11.9 0 0 1 2.534 3.77q.93 2.167.93 4.641t-.93 4.64a11.9 11.9 0 0 1-2.534 3.771 11.9 11.9 0 0 1-3.77 2.534q-2.168.93-4.641.93M13 23a9.9 9.9 0 0 0 3.263-.544 9.3 9.3 0 0 0 2.79-1.523 9.5 9.5 0 0 0-2.754-1.47A10.1 10.1 0 0 0 13 18.938q-1.764 0-3.305.52a9 9 0 0 0-2.748 1.476 9.3 9.3 0 0 0 2.79 1.522A9.9 9.9 0 0 0 13 23m0-10.937q.933 0 1.56-.628.627-.627.627-1.56t-.627-1.56T13 7.687t-1.56.628-.628 1.56.628 1.56 1.56.628"/>
          </svg>
          <span data-qa="connect-dps-common-header-user-name">{{ user.displayName | initialiseName }}</span>
          <span class="govuk-visually-hidden">Account menu</span>
        </span>
      </a>

      <div class="cdps-header__menu cdps-header__menu--user" id="cdps-header__menu--user" hidden="hidden">
        <ul class="govuk-list" aria-label="Account menu">
          <li><a href="{{ manageDetailsLink }}" class="govuk-link govuk-link--no-visited-state">Your account</a></li>
          <li><a href="/sign-out" class="govuk-link govuk-link--no-visited-state">Sign out</a></li>
        </ul>
      </div>
    </div>


    <div class="cdps-header__item cdps-header__item--services">
      <a class="cdps-header__link" href="{{ menuLink }}" data-qa="connect-dps-common-service-menu-toggle">
        <span class="cdps-header__link-wrapper">
          <span class="govuk-visually-hidden">Services</span>
          Menu
        </span>
      </a>
    </div>

    <div class="govuk-!-padding-top-6 govuk-!-padding-bottom-6 cdps-header__menu cdps-header__menu--services" id="cdps-header__menu--services" hidden="hidden">
      <div class="govuk-grid-row">
        <div class="cdps-header__services-wrapper">
          <span class="govuk-label govuk-label--m govuk-!-margin-bottom-4">
            Services
            <span class="govuk-visually-hidden">menu</span>
          </span>
          <ul class="govuk-list cdps-header__services-list" aria-label="Services menu">
            {% for service in user.services %}
              {% if service.navEnabled %}
                {% set serviceLink = service.href %}
                {% if (user.activeCaseLoad.id in config.clientsideAppInsightsEnabledCaseloads) or ('***' in config.clientsideAppInsightsEnabledCaseloads) %}
                  {% set serviceLink = serviceLink + ('&' if '?' in serviceLink else '?') + 'mfeReferralClientId=' + user.clientId %}
                {% endif %}
                <li><a href="{{ serviceLink }}" class="govuk-link govuk-link--no-visited-state">{{ service.heading }}</a></li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>

    <div class="cdps-header__item cdps-header__item--search">
      <a class="cdps-header__link" href="{{ dpsSearchLink }}" data-qa="connect-dps-common-search-toggle">
        <span class="cdps-header__link-wrapper">
          <svg class="cdps-header__icon--search" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="m33 36-8.044-8.4a11.3 11.3 0 0 1-3.259 1.794q-1.841.662-3.92.662-5.146 0-8.712-3.566T5.5 17.778q0-5.148 3.565-8.713T17.778 5.5t8.712 3.565q3.566 3.565 3.566 8.713 0 2.077-.662 3.92a11.3 11.3 0 0 1-1.794 3.258l7.9 8.544Zm-15.222-9.722q3.541 0 6.02-2.48 2.48-2.479 2.48-6.02t-2.48-6.021-6.02-2.48q-3.541 0-6.021 2.48t-2.48 6.02q0 3.543 2.48 6.022t6.02 2.479"/>
          </svg>
          <svg class="cdps-header__icon--close" width="40" height="40" viewBox="0 0 40 40" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="m20 23.56 6.071 6.071 2.121-2.121-6.07-6.07 5.95-5.95-2.122-2.12L20 19.318l-5.95-5.95-2.121 2.121 5.95 5.95-6.071 6.072 2.12 2.122z"/>
          </svg>
        </span>
        <span class="govuk-visually-hidden">
          Prisoner search
        </span>
      </a>
    </div>

    <div class="govuk-!-padding-top-6 govuk-!-padding-bottom-6 cdps-header__menu cdps-header__menu--search" id="cdps-header__menu--search" hidden="hidden">
      <div class="govuk-grid-row">
        <search class="govuk-grid-column-three-quarters">
          <form action="{{ dpsSearchLink }}" method="get" role="search" novalidate>
            {% set buttonHtml %}
              <svg class="cdps-header__icon--search-button" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <path fill="currentColor" d="m16.352 17.975-4.596-4.8a6.577 6.577 0 0 1-4.102 1.403q-2.94 0-4.979-2.037Q.638 10.504.638 7.563t2.037-4.979T7.655.547q2.94 0 4.978 2.037t2.037 4.979a6.58 6.58 0 0 1-1.403 4.101l4.514 4.883zM7.654 12.42q2.024 0 3.44-1.417 1.417-1.416 1.417-3.44t-1.417-3.44Q9.68 2.705 7.654 2.705t-3.44 1.416Q2.797 5.54 2.797 7.562q0 2.025 1.417 3.441 1.415 1.417 3.44 1.417"/>
              </svg>
              <span class="govuk-visually-hidden">
                Search for a prisoner
              </span>
            {% endset %}

            {% set buttonHtml %}
              {{ govukButton({
                html: buttonHtml,
                type: 'submit',
                preventDoubleClick: true,
                classes: 'cdps-header__search-button',
                attributes: {
                  enterkeyhint: 'search'
                }
              }) }}
            {% endset %}

            {{ govukInput({
              label: {
                text: 'Search for a prisoner',
                classes: 'govuk-label--m govuk-!-margin-bottom-4'
              },
              hint: {
                text: 'Enter a prisoner’s name or prison number.'
              },
              name: 'keywords',
              id: 'cdps-header-prisoner-search',
              classes: 'govuk-!-width-three-quarters cdps-header__search-input',
              type: 'search',
              inputmode: 'search',
              spellcheck: false,
              attributes: {
                enterkeyhint: 'search'
              },
              formGroup: {
                afterInput: {
                  html: buttonHtml
                }
              },
              inputWrapper: {
                classes: 'cdps-header__search-wrapper'
              }
            }) }}
          </form>
          <p class="govuk-body">
            <a href="{{ dpsSearchLink }}" class="govuk-link govuk-link--no-visited-state">
              View all prisoners in {{ user.activeCaseLoad.name }}
            </a>
          </p>
        </search>
      </div>
    </div>
  </nav>
</header>
