            </svg>
            {{ user.activeCaseLoad.name }}
          </span>
        </a>
      {% endif %}
    </div>

    <div class="cdps-header__item cdps-header__item--user">
      <a class="cdps-header__link" href="{{ manageDetailsLink }}">
        <span class="cdps-header__link-wrapper">
          <svg class="cdps-header__icon--user" width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d="M 5.52884,19.6154 C 6.59134,18.8269 7.74879,18.2043 9.00119,17.7476 10.25358,17.2909 11.5865,17.0625 13,17.0625 c 1.4134,0 2.7464,0.2284 3.9987,0.6851 1.2524,0.4567 2.4099,1.0793 3.4724,1.8678 0.7772,-0.8542 1.393,-1.843 1.8474,-2.9664 C 22.7728,15.5256 23,14.3093 23,13 23,10.22913 22.026,7.86976 20.0781,5.92184 18.1302,3.97393 15.7708,2.99997 13,2.99997 10.22913,2.99997 7.86976,3.97393 5.92184,5.92184 3.97393,7.86976 2.99997,10.22913 2.99997,13 c 0,1.3093 0.22717,2.5256 0.6815,3.649 0.45433,1.1234 1.07012,2.1122 1.84737,2.9664 z m 7.47146,-5.678 c -1.1412,0 -2.10369,-0.3917 -2.88733,-1.1751 C 9.32932,11.9789 8.9375,11.0166 8.9375,9.87534 8.9375,8.73407 9.3292,7.77161 10.11259,6.98797 10.89601,6.20432 11.8583,5.8125 12.9996,5.8125 c 1.1413,0 2.1037,0.3917 2.8874,1.17509 0.7836,0.78342 1.1754,1.74575 1.1754,2.887 0,1.14131 -0.3917,2.10371 -1.1751,2.88741 -0.7834,0.7836 -1.7457,1.1754 -2.887,1.1754 z M 13,24.8749 c -1.6491,0 -3.19594,-0.3101 -4.64062,-0.9303 C 6.91467,23.3244 5.65785,22.4799 4.58894,21.411 3.52004,20.3421 2.6755,19.0853 2.05531,17.6406 1.435104,16.1959 1.125,14.649 1.125,13 1.125,11.3509 1.435104,9.80406 2.05531,8.35938 2.6755,6.91467 3.52004,5.65785 4.58894,4.58894 5.65785,3.52004 6.91467,2.6755 8.35938,2.05531 9.80406,1.435104 11.3509,1.125 13,1.125 c 1.649,0 3.1959,0.310104 4.6406,0.93031 1.4447,0.62019 2.7015,1.46473 3.7704,2.53363 1.0689,1.06891 1.9134,2.32573 2.5336,3.77044 0.6202,1.44468 0.9303,2.99152 0.9303,4.64062 0,1.649 -0.3101,3.1959 -0.9303,4.6406 -0.6202,1.4447 -1.4647,2.7015 -2.5336,3.7704 -1.0689,1.0689 -2.3257,1.9134 -3.7704,2.5336 C 16.1959,24.5648 14.649,24.8749 13,24.8749 Z M 13,23 c 1.1282,0 2.2159,-0.1815 3.2632,-0.5445 1.0473,-0.363 1.9772,-0.8706 2.7897,-1.5228 -0.8125,-0.6283 -1.7304,-1.1178 -2.7536,-1.4688 -1.0233,-0.351 -2.123,-0.5265 -3.2993,-0.5265 -1.1763,0 -2.27809,0.1735 -3.30534,0.5205 -1.02725,0.3469 -1.94312,0.8385 -2.7476,1.4748 0.8125,0.6522 1.7424,1.1598 2.78969,1.5228 C 10.78402,22.8185 11.8718,23 13,23 Z m 0,-10.9375 c 0.6218,0 1.1418,-0.2091 1.5601,-0.6274 0.4183,-0.4183 0.6274,-0.93834 0.6274,-1.56013 0,-0.62179 -0.2091,-1.14184 -0.6274,-1.56013 C 14.1418,7.89657 13.6218,7.68744 13,7.68744 c -0.6218,0 -1.1419,0.20913 -1.5602,0.6274 -0.4182,0.41829 -0.62736,0.93834 -0.62736,1.56013 0,0.62179 0.20916,1.14183 0.62736,1.56013 0.4183,0.4183 0.9384,0.6274 1.5602,0.6274 z"/>
          </svg>
          <span data-qa="connect-dps-common-header-user-name">{{ user.displayName | initialiseName }}</span>
          <span class="govuk-visually-hidden">Account menu</span>
        </span>
      </a>

      <div class="cdps-header__menu cdps-header__menu--user" id="cdps-header__menu--user" hidden="hidden">
        <ul class="govuk-list" aria-label="Account menu">
          <li><a href="{{ manageDetailsLink }}" class="govuk-link govuk-link--no-visited-state">Your account</a></li>
          <li><a href="/sign-out" class="govuk-link govuk-link--no-visited-state">Sign out</a></li>
        </ul>
      </div>
    </div>


    <div class="cdps-header__item cdps-header__item--services">
      <a class="cdps-header__link" href="{{ menuLink }}">
        <span class="cdps-header__link-wrapper">
          <span class="govuk-visually-hidden">Services</span>
          Menu
        </span>
      </a>
    </div>

    <div class="govuk-!-padding-top-6 govuk-!-padding-bottom-6 cdps-header__menu cdps-header__menu--services" id="cdps-header__menu--services" hidden="hidden">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-three-quarters">
          <span class="govuk-label govuk-label--m govuk-!-margin-bottom-4">
            Services
            <span class="govuk-visually-hidden">menu</span>
          </span>
          <ul class="govuk-list cdps-header__services-list" aria-label="Services menu">
            {% for service in user.services %}
              {% if service.navEnabled %}
                {% set serviceLink = service.href %}
                {% if (user.activeCaseLoad.id in config.clientsideAppInsightsEnabledCaseloads) or ('***' in config.clientsideAppInsightsEnabledCaseloads) %}
                  {% set serviceLink = serviceLink + ('?' if '?' not in serviceLink else '&') + 'mfeReferralClientId=' + user.clientId %}
                {% endif %}
                <li><a href="{{ serviceLink }}" class="govuk-link govuk-link--no-visited-state">{{ service.heading }}</a></li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>

    <div class="cdps-header__item cdps-header__item--search">
      <a class="cdps-header__link" href="{{ dpsSearchLink }}">
        <svg class="cdps-header__icon--search" width="55" height="55" viewBox="0 0 55 55" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
          <path fill="currentColor" d="M42.2778 45L30.0278 32.75C29.0556 33.5278 27.9375 34.1435 26.6736 34.5972C25.4097 35.0509 24.0648 35.2778 22.6389 35.2778C19.1065 35.2778 16.1169 34.0544 13.6701 31.6076C11.2234 29.1609 10 26.1713 10 22.6389C10 19.1065 11.2234 16.1169 13.6701 13.6701C16.1169 11.2234 19.1065 10 22.6389 10C26.1713 10 29.1609 11.2234 31.6076 13.6701C34.0544 16.1169 35.2778 19.1065 35.2778 22.6389C35.2778 24.0648 35.0509 25.4097 34.5972 26.6736C34.1435 27.9375 33.5278 29.0556 32.75 30.0278L45 42.2778L42.2778 45ZM22.6389 31.3889C25.0694 31.3889 27.1354 30.5382 28.8368 28.8368C30.5382 27.1354 31.3889 25.0694 31.3889 22.6389C31.3889 20.2083 30.5382 18.1424 28.8368 16.441C27.1354 14.7396 25.0694 13.8889 22.6389 13.8889C20.2083 13.8889 18.1424 14.7396 16.441 16.441C14.7396 18.1424 13.8889 20.2083 13.8889 22.6389C13.8889 25.0694 14.7396 27.1354 16.441 28.8368C18.1424 30.5382 20.2083 31.3889 22.6389 31.3889Z"/>
        </svg>
        <svg class="cdps-header__icon--close" width="55" height="55" viewBox="0 0 55 55" fill="none" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
          <path fill="currentColor" d="M27.5007 29.5608L33.5711 35.6311L35.6924 33.5098L29.622 27.4395L35.5711 21.4904L33.4498 19.3691L27.5007 25.3181L21.5503 19.3677L19.4289 21.489L25.3794 27.4395L19.3076 33.5112L21.4289 35.6326L27.5007 29.5608Z"/>
        </svg>
        <span class="govuk-visually-hidden">
          Prisoner search
        </span>
      </a>
    </div>

    <div class="govuk-!-padding-top-6 govuk-!-padding-bottom-6 cdps-header__menu cdps-header__menu--search" id="cdps-header__menu--search" hidden="hidden">
      <div class="govuk-grid-row">
        <search class="govuk-grid-column-three-quarters">
          <form action="{{ dpsSearchLink }}" method="get" role="search" novalidate>
            <div class="govuk-form-group">
              <label class="govuk-label govuk-label--m govuk-!-margin-bottom-4" for="cdps-header-prisoner-search">
                Search for a prisoner
              </label>
              <div class="govuk-hint">
                Enter a prisoner’s name or prison number.
              </div>
              <div class="govuk-input__wrapper">
                <input class="govuk-input govuk-!-width-three-quarters" id="cdps-header-prisoner-search" name="keywords" type="search" enterkeyhint="search" spellcheck="false">
                <button class="govuk-input__suffix cdps-header__search-button" data-module="govuk-button" type="submit" enterkeyhint="search">
                  <svg class="cdps-header__icon--search-button" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path fill="currentColor" d="m 18.4444,20 -7,-7 c -0.5555,0.4444 -1.1944,0.7963 -1.9166,1.0556 -0.7222,0.2592 -1.4908,0.3888 -2.3056,0.3888 -2.0185,0 -3.7268,-0.699 -5.125,-2.0972 C 0.6991,10.9491 0,9.2407 0,7.2222 0,5.2037 0.6991,3.4954 2.0972,2.0972 3.4954,0.6991 5.2037,0 7.2222,0 c 2.0185,0 3.7269,0.6991 5.125,2.0972 1.3982,1.3982 2.0972,3.1065 2.0972,5.125 0,0.8148 -0.1296,1.5834 -0.3888,2.3056 C 13.7963,10.25 13.4444,10.8889 13,11.4444 l 7,7 z M 7.2222,12.2222 c 1.3889,0 2.5695,-0.4861 3.5417,-1.4583 0.9722,-0.9722 1.4583,-2.1528 1.4583,-3.5417 0,-1.3889 -0.4861,-2.5694 -1.4583,-3.5416 C 9.7917,2.7083 8.6111,2.2222 7.2222,2.2222 5.8333,2.2222 4.6528,2.7083 3.6806,3.6806 2.7083,4.6528 2.2222,5.8333 2.2222,7.2222 c 0,1.3889 0.4861,2.5695 1.4584,3.5417 0.9722,0.9722 2.1527,1.4583 3.5416,1.4583 z"/>
                  </svg>
                  <span class="govuk-visually-hidden">
                    Search for a prisoner
                  </span>
                </button>
              </div>
            </div>
          </form>
          <p class="govuk-body">
            <a href="{{ dpsSearchLink }}" class="govuk-link govuk-link--no-visited-state">
              View all prisoners in {{ user.activeCaseLoad.name }}
            </a>
          </p>
        </search>
      </div>
    </div>
  </nav>
</header>
